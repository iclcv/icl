<scene>
  <!-- Camera: Z-up, looking at origin from above-right -->
  <camera pos="500 -400 350" dir="-0.6 0.5 -0.35" up="0 0 -1" res="640x480"/>

  <!-- Main light (dimmable via scale) -->
  <light pos="200 -200 500" diffuse="255 245 220" ambient="35 33 30" scale="1.0"/>

  <!-- Table (flat box) -->
  <object type="cube" pos="0 0 -40" size="500" sx="1" sy="0.7" sz="0.04"
          color="140 100 60"/>

  <!-- Glowing sphere (area light source) -->
  <object type="sphere" pos="0 0 50" radius="35"
          color="255 220 150" emission="255 230 180" emissionIntensity="1.5"/>

  <!-- Red cube to the left -->
  <object type="cube" pos="-120 -40 0" size="50" color="200 60 60"/>

  <!-- Blue cube to the right (slightly reflective) -->
  <object type="cube" pos="130 30 -5" size="40" color="60 80 200" reflectivity="0.3"/>

  <!-- Green sphere behind -->
  <object type="sphere" pos="30 100 5" radius="30" color="60 180 80"/>

  <!-- Shiny mirror sphere in front -->
  <object type="sphere" pos="-40 -90 5" radius="25"
          color="220 220 230" reflectivity="0.8"/>
</scene>
