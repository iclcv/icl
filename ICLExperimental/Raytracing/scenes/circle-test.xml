<scene>
  <!-- Top-down view looking straight at ground -->
  <camera pos="0 0 500" dir="0 0 -1" up="0 1 0" res="640x640"/>
  <light pos="200 -200 500" diffuse="255 245 220" ambient="5 5 5" scale="0.0"/>

  <!-- Ground -->
  <object type="cube" pos="0 0 -10" size="800" sx="1" sy="1" sz="0.01"
          color="200 190 180"/>

  <!-- Central glowing sphere -->
  <object type="sphere" pos="0 0 60" radius="25"
          color="255 240 200" emission="255 240 200" emissionIntensity="2.0"/>

  <!-- 8 cubes in a circle (radius 120, size 40) -->
  <object type="cube" pos="120 0 15"     size="40" color="200 60 60"/>
  <object type="cube" pos="85 85 15"     size="40" color="60 180 60"/>
  <object type="cube" pos="0 120 15"     size="40" color="60 60 200"/>
  <object type="cube" pos="-85 85 15"    size="40" color="200 200 60"/>
  <object type="cube" pos="-120 0 15"    size="40" color="200 60 200"/>
  <object type="cube" pos="-85 -85 15"   size="40" color="60 200 200"/>
  <object type="cube" pos="0 -120 15"    size="40" color="200 130 60"/>
  <object type="cube" pos="85 -85 15"    size="40" color="130 60 200"/>
</scene>
