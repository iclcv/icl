<scene>
  <!-- Camera: Z-up, looking at origin from above-right -->
  <camera pos="500 -400 350" dir="-0.6 0.5 -0.35" up="0 0 -1" res="640x480"/>

  <!-- Scene lights OFF (scale=0) to isolate area light effect -->
  <light pos="200 -200 500" diffuse="255 245 220" ambient="10 10 10" scale="0.0"/>

  <!-- Table -->
  <object type="cube" pos="0 0 -40" size="500" sx="1" sy="0.7" sz="0.04"
          color="180 160 140"/>

  <!-- Glowing sphere (sole light source) -->
  <object type="sphere" pos="0 0 80" radius="30"
          color="255 240 200" emission="255 240 200" emissionIntensity="2.0"/>

  <!-- Cube that should receive light + cast shadow -->
  <object type="cube" pos="-80 0 0" size="50" color="200 60 60"/>

  <!-- Another cube -->
  <object type="cube" pos="80 40 -5" size="40" color="60 80 200"/>
</scene>
