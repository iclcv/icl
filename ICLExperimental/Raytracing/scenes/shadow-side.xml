<scene>
  <!-- Side view to see shadow shape clearly -->
  <camera pos="350 -50 80" dir="-1 0.1 -0.1" up="0 0 -1" res="640x480"/>
  <light pos="200 -200 500" diffuse="255 245 220" ambient="5 5 5" scale="0.0"/>

  <!-- Ground -->
  <object type="cube" pos="0 0 -35" size="600" sx="1" sy="1" sz="0.02"
          color="200 190 170"/>

  <!-- Glowing sphere offset to one side so shadow is visible -->
  <object type="sphere" pos="60 0 130" radius="25"
          color="255 240 200" emission="255 240 200" emissionIntensity="2.5"/>

  <!-- Cube casting shadow -->
  <object type="cube" pos="0 0 15" size="60" color="180 50 50"/>
</scene>
